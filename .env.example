# Copy this file to .env (and add the same values in Vercel → Project → Settings → Environment Variables)

# --- Database (Vercel Postgres / Neon — created automatically when you add the
# "Postgres" storage integration in your Vercel project) ---
POSTGRES_URL="postgres://user:password@host:5432/dbname"

# --- File storage for media library / product images (Vercel Blob) ---
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxx"

# --- Auth ---
JWT_SECRET="replace-with-a-long-random-string"

# --- Paystack ---
# Get these from https://dashboard.paystack.com/#/settings/developers
PAYSTACK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxx"
PAYSTACK_PUBLIC_KEY="pk_test_xxxxxxxxxxxxxxxxxxxx"

# Used to build the callback URL Paystack redirects back to after payment
PUBLIC_BASE_URL="https://your-site.vercel.app"
